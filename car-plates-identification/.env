# Azure AI Foundry Configuration
# Replace the placeholder values with your actual Azure AI Foundry credentials

# Your Azure AI Foundry endpoint URL
# For Azure Cognitive Services with OpenAI models, use this format
AZURE_AI_ENDPOINT=https://your-resources.cognitiveservices.azure.com/openai/deployments/gpt-4o

# Your Azure AI Foundry API key
AZURE_AI_API_KEY=your_azure_ai_api_key_here

# Model deployment name (use a vision-capable model like gpt-4o)
AZURE_AI_MODEL=gpt-4o

# ============================================
# Azure AI Vision (Image Analysis) Configuration
# For plate_reader_vision.py script
# ============================================

# Your Azure AI Vision endpoint URL
AZURE_VISION_ENDPOINT=https://swedencentral.api.cognitive.microsoft.com/

# Your Azure AI Vision API key
AZURE_VISION_API_KEY=your_azure_ai_vision_api_key_here
